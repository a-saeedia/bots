# Database (PostgreSQL — Supabase, Neon, Railway, or local Docker)
DATABASE_URL=postgresql://user:password@localhost:5432/quiz_bot?schema=public

# Server
PORT=3000
APP_ORIGIN=http://localhost:3000

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# Bale (optional — leave empty to disable)
BALE_BOT_TOKEN=

# Admin panel
ADMIN_PASSWORD=change_me

# Google Sheets sync (optional — JSON string of service account credentials)
GOOGLE_CREDENTIALS_JSON=
